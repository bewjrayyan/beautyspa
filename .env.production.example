# =============================================================================
# AestheticCart — PRODUCTION .env (optimized)
# Copy to server as .env and fill secrets. Do NOT commit real .env to Git.
# Local dev: use .env.example instead.
# After edit: php artisan config:clear && php artisan cache:clear && php artisan optimize
# =============================================================================

# --- Application ---
APP_ENV=production
APP_DEBUG=false
APP_CACHE=true
APP_INSTALLED=true
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_NAME=AestheticCart
APP_URL=https://immaserilaris.com/v2
APP_TIMEZONE=Asia/Kuala_Lumpur

# --- Security headers (docs/SECURITY.md) ---
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_ENABLED=false
SECURITY_CSP_REPORT_ONLY=true
SECURITY_HSTS_ENABLED=true

# Behind Cloudflare / load balancer (required for correct HTTPS + sessions)
TRUSTED_PROXIES=*

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=error

# --- Database ---
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

# --- Queue (do NOT use sync on production) ---
QUEUE_DRIVER=database
# QUEUE_DRIVER=redis

# Run worker (Supervisor recommended):
# php artisan queue:work --sleep=3 --tries=3 --max-time=3600

# --- Cache & session (Redis recommended) ---
CACHE_DRIVER=redis
SESSION_DRIVER=redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Fallback if Redis not installed yet:
# CACHE_DRIVER=file
# SESSION_DRIVER=file

# Do NOT point FLEETCART_* to /tmp on production — leave unset (uses storage/)
# FLEETCART_CACHE_PATH=
# FLEETCART_LOG_PATH=
# FLEETCART_SESSION_PATH=
# FLEETCART_VIEW_COMPILED_PATH=

# --- Performance / full-page HTML cache (guest) ---
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_HOME_ENABLED=true
RESPONSE_CACHE_TTL_MINUTES=15
RESPONSE_CACHE_SLUGS=faq,terms-conditions,privacy-policy

# CDN: only set when you have a real CDN origin (NOT a placeholder domain)
# Same origin + Cloudflare in front is fine — leave commented:
# ASSET_CDN_URL=https://immaserilaris.com/v2
# MEDIA_CDN_URL=https://immaserilaris.com/v2

# IMAGE_WEBP_ENABLED=true
# IMAGE_REPLACE_WITH_WEBP=true
# IMAGE_WEBP_QUALITY=82
# IMAGE_RESPONSIVE_WIDTHS=480,960

# --- Session cookies (HTTPS) ---
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# --- Filesystem ---
FILESYSTEM_DRIVER=public_storage

# --- Mail ---
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-user
MAIL_PASSWORD=your-smtp-password
MAIL_FROM_ADDRESS=orders@immaserilaris.com
MAIL_FROM_NAME="Imma Serilaris"
MAIL_ENCRYPTION=tls

# --- Debug / dev tools (must stay off) ---
DEBUGBAR_ENABLED=false
QUERY_DETECTOR_ENABLED=false
IGNITION_EDITOR=vscode

# --- WhatsApp / OneSender (optional .env overrides; admin Settings also apply) ---
# ONESENDER_ENABLED=true
# ONESENDER_API_URL=https://wa3269.cloudwa.my.id/api/v1/messages
# ONESENDER_API_KEY=
# ONESENDER_ADMIN_PHONES=
# ONESENDER_WHATSAPP_GROUP_ID=
# ONESENDER_OUTBOUND_QUEUE_ENABLED=true
# ONESENDER_OUTBOUND_DELAY_SECONDS=30
# WHATSAPP_WELCOME_ENABLED=true
# WHATSAPP_ORDER_TRACKING_URL=https://immaserilaris.com/v2/order-tracking

# Production only — never needed when APP_ENV=production:
# ONESENDER_ALLOW_IN_LOCAL=false

# --- Optional ---
SCOUT_QUEUE=false
DATATABLES_ERROR=null
MAILCHIMP_APIKEY=

# --- Cron (required) ---
# * * * * * cd /path/to/v2 && php artisan schedule:run >> /dev/null 2>&1
