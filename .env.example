#Application
APP_ENV=local
APP_DEBUG=true
APP_CACHE=true
APP_INSTALLED=false
APP_KEY=
APP_NAME=AestheticCart
# Include subdirectory when not at domain root, e.g. https://example.com/v2
APP_URL=http://localhost/fleetcart

#Catalog sync (Admin → Settings → System): same token on local + production
#CATALOG_SYNC_TOKEN=your-secret-token-here
#CATALOG_SYNC_SOURCE_URL=http://localhost/fleetcart/catalog-sync/bundle

#Security headers (see docs/SECURITY.md)
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_ENABLED=false
SECURITY_CSP_REPORT_ONLY=true
#SECURITY_CSP_REPORT_URI=
SECURITY_HSTS_ENABLED=true

#Ignition
IGNITION_EDITOR=vscode

#Logging
LOG_CHANNEL=stack

#Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homestead
DB_USERNAME=homestead
DB_PASSWORD=secret

#Queue
QUEUE_DRIVER=sync

#Cache
CACHE_DRIVER=file
# CACHE_DRIVER=redis

#Performance / CDN (see docs/PERFORMANCE.md)
# ASSET_CDN_URL=
# MEDIA_CDN_URL=
# STOREFRONT_LAYOUT_CACHE_TTL=3600

#Session
SESSION_DRIVER=file

#File System
FILESYSTEM_DRIVER=public_storage

#Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

#Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME=null
MAIL_ENCRYPTION=null

#Mailchimp
MAILCHIMP_APIKEY=

#AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

#Scout
SCOUT_QUEUE=false

#Laravel DataTables (yajra/laravel-datatables)
DATATABLES_ERROR=null

#Debugbar for Laravel (barryvdh/laravel-debugbar)
DEBUGBAR_ENABLED=false

#Laravel Query Detector (beyondcode/laravel-query-detector)
QUERY_DETECTOR_ENABLED=false

#Production scheduler (required for appointment reminders & follow-ups)
#Add to server crontab: * * * * * cd /path/to/fleetcart && php artisan schedule:run >> /dev/null 2>&1
#See docs/TREATMENT_RESERVATION.md for TreatmentReservation WhatsApp & cron setup.

