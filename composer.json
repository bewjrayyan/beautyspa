{
    "name": "mediacreativesolution/aestheticcart",
    "description": "The AestheticCart e-commerce CMS (BeautySpa).",
    "type": "project",
    "authors": [
        {
            "name": "MediaCreative Solution",
            "email": "bewjrayyan@gmail.com"
        }
    ],
    "repositories": [
        {
            "type": "package",
            "package": {
                "name": "maatwebsite/laravel-sidebar",
                "version": "3.1.0",
                "dist": {
                    "type": "zip",
                    "url": "https://api.github.com/repos/Maatwebsite/Laravel-Sidebar/zipball/master"
                },
                "require": {
                    "php": "^8.1",
                    "illuminate/cache": "~10.0|~11.0",
                    "illuminate/container": "~10.0|~11.0",
                    "illuminate/contracts": "~10.0|~11.0",
                    "illuminate/support": "~10.0|~11.0",
                    "illuminate/routing": "~10.0|~11.0",
                    "illuminate/view": "~10.0|~11.0"
                },
                "autoload": {
                    "psr-4": {
                        "Maatwebsite\\Sidebar\\": "src/"
                    }
                },
                "extra": {
                    "laravel": {
                        "providers": [
                            "Maatwebsite\\Sidebar\\SidebarServiceProvider"
                        ]
                    }
                }
            }
        },
        {
            "type": "package",
            "package": {
                "name": "tinycolor/tinycolor",
                "version": "1.0.1",
                "dist": {
                    "type": "zip",
                    "url": "https://api.github.com/repos/ScoLib/tinycolor-php/zipball/master"
                },
                "require": {
                    "php": "^8.1"
                },
                "autoload": {
                    "psr-4": {
                        "TinyColor\\": "src"
                    },
                    "files": [
                        "./src/util.php"
                    ]
                }
            }
        }
    ],
    "require": {
        "php": "^8.2.0",
        "ext-gd": "*",
        "cache/predis-adapter": "^1.0",
        "doctrine/dbal": "^4.0",
        "dompdf/dompdf": "^3.0",
        "guzzlehttp/guzzle": "^7.2",
        "koel/dotenv-editor": "^3.0",
        "laravel/framework": "^11.0",
        "laravel/helpers": "^1.7",
        "laravel/legacy-factories": "^1.0",
        "nwidart/laravel-modules": "^11.0",
        "psr/http-factory": "^1.0.2",
        "silviolleite/laravelpwa": "~2.0.3",
        "swayok/alternative-laravel-cache": "^6.1",
        "swayok/cache-filesystem-adapter": "^1.3",
        "symfony/http-client": "^7.0",
        "symfony/intl": "^7.0",
        "wikimedia/composer-merge-plugin": "^2.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.0",
        "beyondcode/laravel-dump-server": "^2.0",
        "beyondcode/laravel-query-detector": "^2.0",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "*",
        "laravel/tinker": "^2.7",
        "nunomaduro/collision": "^8.8",
        "nunomaduro/phpinsights": "^2.10",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "AestheticCart\\": "app/",
            "Modules\\": "modules/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "preferred-install": "dist",
        "github-protocols": ["https"],
        "platform": {
            "php": "8.2.0"
        },
        "allow-plugins": {
            "wikimedia/composer-merge-plugin": true,
            "php-http/discovery": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "nwidart/laravel-modules",
                "swayok/alternative-laravel-cache"
            ]
        },
        "branch-alias": {
            "dev-master": "1.0.x-dev"
        },
        "merge-plugin": {
            "require": [
                "modules/*/composer.json"
            ],
            "merge-extra": true,
            "merge-extra-deep": true,
            "merge-scripts": true
        }
    }
}
